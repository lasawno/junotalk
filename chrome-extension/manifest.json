{
  "manifest_version": 3,
  "name": "Juno AI Assistant",
  "version": "1.0.0",
  "description": "Voice chat, real-time translation, and AI assistance on any page — powered by Juno. One focused purpose, transparent data handling.",

  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://9148d0f9-2be6-4c0b-8751-ef3b2ad7f6c4-00-2fmgrlf2nn4u7.picard.replit.dev/*"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "action": {
    "default_title": "Open Juno",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
